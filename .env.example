# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Nano Banana / Gemini API (图片生成)
GEMINI_API_KEY=your_gemini_api_key

# Jina Reader API（网页内容提取，可选）
# 不配置也能用（免费 20 RPM），配置后提升到 500 RPM
# 注册获取：https://jina.ai/reader
JINA_API_KEY=

# TrendRadar MCP 服务地址（启动后支持 40+ 平台：微博/知乎/百度/头条/B站/华尔街见闻/掘金 等）
# 部署方式：docker-compose up -d trendradar
# 平台配置：修改 trendradar-config/config.yaml 中的 platforms 列表
# 不配置则回退到内置抓取（仅 Google News / Bing News）
TRENDRADAR_MCP_URL=http://localhost:3001/mcp

# xiaohongshu-mcp (https://github.com/xpzouying/xiaohongshu-mcp)
# 部署方式：docker compose up -d xiaohongshu-mcp
# 首次使用需扫码登录小红书
XHS_MCP_URL=http://localhost:18060/mcp

# Server
PORT=3000
UPLOAD_DIR=./uploads
