{
  "name": "xhs-ai-operator",
  "version": "1.0.0",
  "description": "AI 小红书运营工作台 - 热点追踪 → 内容生成 → 一键发布",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "node --watch server/app.js",
    "dev:web": "cd web && npm run dev",
    "build": "cd web && npm run build",
    "start": "NODE_ENV=production node server/app.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "defuddle": "^0.12.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsdom": "^25.0.1",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.73.0",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
